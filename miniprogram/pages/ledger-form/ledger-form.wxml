<view class="page">
  <view class="card">
    <view class="row">
      <view class="label">名称</view>
      <input
        class="input"
        placeholder="如：家庭账本"
        maxlength="20"
        value="{{ name }}"
        bindinput="onName"
      />
    </view>
    <view class="row">
      <view class="label">颜色</view>
      <view class="colors">
        <view
          wx:for="{{ colors }}"
          wx:key="*this"
          class="color-dot {{ color === item ? 'selected' : '' }}"
          style="background:{{ item }}"
          data-color="{{ item }}"
          bindtap="pickColor"
        ></view>
      </view>
    </view>
  </view>

  <view class="submit" bindtap="submit">创建账本</view>
</view>
