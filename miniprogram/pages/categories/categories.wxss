.page { padding: 24rpx; min-height: 100vh; }
.type-tabs { display: flex; justify-content: center; margin-bottom: 24rpx; }
.tab {
  width: 160rpx; height: 56rpx; line-height: 56rpx;
  text-align: center; border-radius: 28rpx;
  background: #fff; color: #969799; margin: 0 12rpx;
  font-size: 26rpx;
}
.tab.active { background: #4A90E2; color: #fff; }

.list { background: #fff; border-radius: 16rpx; padding: 8rpx 32rpx; }
.item { display: flex; align-items: center; padding: 24rpx 0; border-top: 1rpx solid #ebedf0; }
.item:first-child { border-top: none; }
.icon {
  width: 64rpx; height: 64rpx; border-radius: 16rpx;
  color: #fff; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx; flex-shrink: 0;
}
.icon .emoji {
  font-size: 32rpx;
  line-height: 1;
}
.name { flex: 1; font-size: 28rpx; }
.tag {
  background: #f7f8fa; color: #969799;
  padding: 4rpx 16rpx; border-radius: 16rpx;
  font-size: 22rpx;
}

.hint { text-align: center; padding: 48rpx 0; font-size: 24rpx; }
