.record-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fff;
}

/* 类型切换 */
.type-tabs {
  display: flex;
  justify-content: center;
  padding: 24rpx 0;
  background: #fff;
}

.tab {
  width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 30rpx;
  color: #969799;
  border-radius: 32rpx;
  margin: 0 16rpx;
  background: #f7f8fa;
}

.tab.active {
  color: #fff;
  background: #4A90E2;
}

/* 金额 */
.amount-area {
  text-align: right;
  padding: 24rpx 32rpx 16rpx;
}

.amount-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
}

.amount-symbol {
  font-size: 36rpx;
  margin-right: 8rpx;
  color: #323233;
}

.amount-value {
  font-size: 72rpx;
  font-weight: 600;
  color: #323233;
}

.amount-value.placeholder {
  color: #c8c9cc;
}

/* 分类 */
.section-title {
  padding: 16rpx 32rpx 8rpx;
  color: #969799;
  font-size: 24rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx 24rpx;
}

.category-item {
  width: 20%;
  text-align: center;
  padding: 16rpx 0;
  box-sizing: border-box;
}

.category-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin: 0 auto;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.6;
  transition: all 0.2s;
}

.category-icon .emoji {
  font-size: 44rpx;
  line-height: 1;
}

.category-item.selected .category-icon {
  opacity: 1;
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.category-name {
  font-size: 22rpx;
  color: #646566;
  margin-top: 8rpx;
}

.category-item.selected .category-name {
  color: #4A90E2;
  font-weight: 500;
}

/* 其他字段 */
.extras {
  padding: 0 32rpx;
}

.extra-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #ebedf0;
}

.extra-label {
  width: 140rpx;
  color: #646566;
  font-size: 26rpx;
}

.extra-value {
  flex: 1;
  font-size: 26rpx;
}

.extra-input {
  flex: 1;
  font-size: 26rpx;
}

/* 图片上传 */
.image-row {
  align-items: flex-start;
}

.image-list {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 0 0 0 12rpx;
  font-size: 28rpx;
}

.image-add {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #c8c9cc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #969799;
}

.image-add .plus {
  font-size: 48rpx;
  line-height: 1;
}

.image-add .hint {
  font-size: 20rpx;
  margin-top: 4rpx;
}

/* 数字键盘 */
.keyboard {
  margin-top: auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(4, 96rpx);
  gap: 2rpx;
  background: #ebedf0;
  padding-top: 2rpx;
}

.key {
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #323233;
}

.key:active {
  background: #f7f8fa;
}

.key-fn {
  background: #f7f8fa;
  font-size: 32rpx;
}

.key-date {
  background: #f7f8fa;
  font-size: 24rpx;
  color: #646566;
}

.key-save {
  background: #4A90E2;
  color: #fff;
  font-size: 32rpx;
}

.key-double {
  grid-row: span 2;
}
