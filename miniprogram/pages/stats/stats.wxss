.stats-page { min-height: 100vh; padding: 24rpx; }

.month-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.nav-arrow {
  width: 60rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #323233;
}
.nav-arrow.disabled { color: #c8c9cc; }
.nav-label {
  font-size: 30rpx; font-weight: 600;
  margin: 0 24rpx;
}

.overview {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  margin-bottom: 24rpx;
}
.ov-item { flex: 1; text-align: center; }
.ov-label { font-size: 24rpx; color: #969799; margin-bottom: 8rpx; }
.ov-value { font-size: 32rpx; font-weight: 600; }

.type-tabs { display: flex; justify-content: center; margin-bottom: 24rpx; }
.tab {
  width: 160rpx; height: 56rpx; line-height: 56rpx;
  text-align: center; border-radius: 28rpx;
  background: #fff; color: #969799; margin: 0 12rpx;
  font-size: 26rpx;
}
.tab.active { background: #4A90E2; color: #fff; }

.rank-title { font-size: 28rpx; font-weight: 600; margin-bottom: 24rpx; }

.rank-item {
  display: flex; align-items: center; padding: 16rpx 0;
}

.rank-icon {
  width: 64rpx; height: 64rpx; border-radius: 16rpx;
  color: #fff; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 24rpx; flex-shrink: 0;
}

.rank-icon .emoji {
  font-size: 32rpx;
  line-height: 1;
}

.rank-main { flex: 1; min-width: 0; }
.rank-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.rank-name { font-size: 28rpx; }
.rank-amount { font-size: 28rpx; font-weight: 500; }
.rank-bar { height: 8rpx; background: #f7f8fa; border-radius: 4rpx; overflow: hidden; }
.rank-bar-inner { height: 100%; }
.rank-percent { font-size: 22rpx; margin-top: 4rpx; }

.empty { text-align: center; padding: 200rpx 0; }

.aa-action {
  padding: 24rpx 0;
}
.btn-aa {
  background: #4A90E2;
  color: #fff;
  font-size: 30rpx;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
}
