.page { padding: 80rpx 48rpx; min-height: 100vh; text-align: center; }
.hero { font-size: 120rpx; }
.title { font-size: 40rpx; font-weight: 600; margin: 24rpx 0; }
.hint { font-size: 26rpx; margin-bottom: 32rpx; }

.input {
  width: 100%; box-sizing: border-box;
  height: 96rpx; line-height: 96rpx;
  background: #fff; border-radius: 16rpx;
  text-align: center; font-size: 36rpx;
  letter-spacing: 12rpx;
  margin-bottom: 32rpx;
}

.btn-primary {
  height: 96rpx; line-height: 96rpx;
  background: #4A90E2; color: #fff;
  border-radius: 48rpx; font-size: 32rpx;
}
