.index-page {
  min-height: 100vh;
  padding-bottom: 200rpx;
  background: #f7f8fa;
}

/* 顶部账本切换 */
.header {
  padding: 32rpx 32rpx 16rpx;
}

.ledger-name {
  font-size: 36rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
}

.caret {
  font-size: 24rpx;
  margin-left: 8rpx;
  color: #969799;
}

/* 月度概览大卡 */
.overview-card {
  margin: 16rpx 24rpx 24rpx;
  background: linear-gradient(135deg, #4A90E2 0%, #6BB1FF 60%, #7BC1FF 100%);
  color: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 226, 0.25);
  position: relative;
  overflow: hidden;
}

/* 卡片角落装饰圆 */
.overview-card::before {
  content: '';
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  top: -120rpx;
  right: -100rpx;
}

.overview-card::after {
  content: '';
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  bottom: -80rpx;
  left: -60rpx;
}

/* 月份切换 */
.month-switch {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.month-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  line-height: 1;
}

.month-arrow.disabled {
  opacity: 0.3;
}

.month-label {
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 大金额展示 */
.big-amount {
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: baseline;
  position: relative;
}

.big-symbol {
  font-size: 32rpx;
  margin-right: 8rpx;
  font-weight: 500;
}

.big-value {
  font-size: 80rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.big-tip {
  text-align: center;
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 8rpx;
  position: relative;
}

.overview-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 28rpx 0 20rpx;
  position: relative;
}

.sub-row {
  display: flex;
  justify-content: space-around;
  position: relative;
}

.sub-item {
  text-align: center;
  flex: 1;
}

.sub-label {
  font-size: 22rpx;
  opacity: 0.85;
  margin-bottom: 6rpx;
}

.sub-value {
  font-size: 30rpx;
  font-weight: 600;
}

/* 列表 */
.list {
  margin: 0 24rpx;
}

.group {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fafbfc;
}

.group-date {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.group-day {
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
}

.group-week {
  font-size: 22rpx;
  color: #969799;
}

.group-summary {
  font-size: 22rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-top: 1rpx solid #f0f1f3;
  transition: background 0.15s;
}

.record-item:active {
  background: #f7f8fa;
}

.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.record-icon .emoji {
  font-size: 36rpx;
  line-height: 1;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-name {
  font-size: 30rpx;
  color: #323233;
  font-weight: 500;
}

.record-note {
  font-size: 24rpx;
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #969799;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 600;
  margin-left: 16rpx;
}

.load-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #c8c9cc;
}

/* 浮动 + 按钮 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 64rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90E2 0%, #6BB1FF 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(74, 144, 226, 0.45);
  z-index: 99;
  transition: transform 0.2s;
}

.fab:active {
  transform: scale(0.92);
}

.fab-plus {
  font-size: 64rpx;
  line-height: 1;
  font-weight: 300;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  line-height: 1;
  opacity: 0.6;
}

.empty-title {
  margin-top: 32rpx;
  font-size: 30rpx;
  color: #646566;
  font-weight: 500;
}

.empty-tip {
  margin-top: 12rpx;
  color: #969799;
  font-size: 24rpx;
}
