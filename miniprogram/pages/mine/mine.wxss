.mine-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.profile {
  display: flex;
  align-items: center;
  padding: 48rpx 32rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.avatar-wrap {
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ebedf0;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #969799;
  background: #f7f8fa;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.hint {
  font-size: 24rpx;
}

.cell-group {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.cell {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-top: 1rpx solid #ebedf0;
}

.cell:first-child {
  border-top: none;
}

.cell-label {
  flex: 1;
  font-size: 30rpx;
}

.cell-arrow {
  color: #c8c9cc;
  font-size: 32rpx;
}

/* 弹层 */
.mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex; align-items: center; justify-content: center;
}

.modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
}

.modal-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid #ebedf0;
}

.form-row:first-of-type {
  border-top: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #646566;
}

.avatar-button {
  background: transparent;
  padding: 0;
  margin: 0;
  line-height: normal;
  border: none;
}
.avatar-button::after {
  border: none;
}

.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  font-size: 22rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
}

.modal-actions {
  display: flex;
  margin-top: 32rpx;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.modal-btn-cancel {
  background: #f7f8fa;
  color: #646566;
}

.modal-btn-confirm {
  background: #4A90E2;
  color: #fff;
}
